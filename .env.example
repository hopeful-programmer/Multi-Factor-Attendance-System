# Picovoice Eagle API key — requires a Picovoice account (https://picovoice.ai/)
PICOVOICE_ACCESS_KEY=your_access_key_here

# MySQL connection
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=attendance_db

# Microphone device index (-1 = system default, which works for most setups)
# To list available devices: python -c "from pvrecorder import PvRecorder; print(PvRecorder.get_available_devices())"
MIC_DEVICE_INDEX=-1
CAM_DEVICE_INDEX=0

